# =============================================
# Rumo Praga - Variaveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Supabase - Obtenha em https://supabase.com/dashboard/project/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Stripe - Obtenha em https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google OAuth - Obtenha em https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# RevenueCat - Obtenha em https://app.revenuecat.com > Project Settings > API Keys
# SDK key publica (appl_XXXX / goog_XXXX) — NAO e a secret key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Sentry - DSN publico (seguro no client)
# Obtenha em https://sentry.io > Project Settings > Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# Feature flags (default: todas habilitadas)
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# Voice recorder UI stub (default: OFF — flip to true ONLY after IA Hub PR #18
# merges, IA Hub web deploys, and 48h Sentry soak passes per ZERO-P).
# When OFF, VoiceRecorderButton renders null — zero impact on prod.
# EAS env: set via `eas env:create --visibility plaintext` (ZERO-L: EXPO_PUBLIC_*
# vars MUST be plaintext, never SECRET, or runtime bundles get "***" garbage).
EXPO_PUBLIC_VOICE_ENABLED=false

# Rumo IA Hub (IH-6) — cross-app AI gateway for diagnose / chat
# Per-app token issued by the IA Hub admin (NAO e a service-role do Supabase)
# Plaintext em EAS conforme ZERO-L: o token e app-scoped + rate-limited.
EXPO_PUBLIC_IA_HUB_API_KEY=
EXPO_PUBLIC_IA_HUB_URL=https://iahub.agrorumo.com
# Quando "true", o diagnose vai pelo IA Hub. Default fica em legado
# (Supabase /functions/v1/diagnose) ate o rollout terminar.
EXPO_PUBLIC_IA_HUB_ENABLED=false


# === BUILD-TIME ONLY (EAS secret, NAO expor no client) ===
# Configure como EAS secret:
#   eas secret:create --scope project --name SENTRY_AUTH_TOKEN --value sntrys_XXXX
#
# SENTRY_AUTH_TOKEN=  # usado pelo @sentry/react-native plugin pra upload de source maps

# === CHAVES SERVER-SIDE (NAO colocar no app mobile) ===
# Estas chaves devem estar APENAS nas Supabase Edge Functions
# Configure com: supabase secrets set CHAVE=valor
#
# STRIPE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# CLAUDE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# GOOGLE_GEMINI_API_KEY=
# RESEND_API_KEY=
