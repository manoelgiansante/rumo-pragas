# =============================================
# Rumo Pragas - Variáveis de ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Supabase - Obtenha em https://supabase.com/dashboard/project/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EAS: cadastre ambas como plaintext nos ambientes usados pelo build.

# Google OAuth - IDs distintos são obrigatórios no candidato production.
# Obtenha em
# https://console.cloud.google.com/apis/credentials
# NUNCA reutilize o Web Client ID no iOS/Android. Se o ID específico da
# plataforma estiver ausente ou malformado, builds internos escondem o botão,
# mas o runner production falha fechado antes de prebuild/archive.
# Cadastre cada valor público pelo dashboard/API administrativo do EAS Environment.
# O executor local usa allowlist somente-leitura e bloqueia env:create.
# O iOS deve usar bundle com.agrorumo.rumopragas; Android deve usar package
# com.agrorumo.rumopragas + SHA-1 da assinatura correspondente.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Sentry - DSN publico (seguro no client)
# Obtenha em https://sentry.io > Project Settings > Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=
# EAS: cadastre como plaintext nos ambientes usados pelo build.

# Feature flags (default: todas habilitadas)
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# === BUILD-TIME ONLY (NAO expor no client) ===
# Android remote push (FCM v1): o runner production aceita somente o arquivo
# local aprovado em /Volumes/RumoPragasProdBackup/credentials/firebase/
# google-services-rumo-pragas.json. Ele valida hash, project/app/package, cria
# snapshot 0600 efêmero e nunca depende de EAS File Secret.
#
# Configure como secret no EAS Environment. Não use --value para secrets: o
# prompt interativo oculto evita gravar o token no histórico e na lista de processos.
# Cadastre SENTRY_AUTH_TOKEN pelo dashboard/API administrativo autorizado; a
# allowlist do executor local não permite mutações env:create.
#
# GOOGLE_SERVICES_JSON=  # definido apenas pelo runner a partir do snapshot local aprovado
# SENTRY_AUTH_TOKEN=     # upload de source maps do @sentry/react-native

# === CHAVES SERVER-SIDE (NAO colocar no app mobile) ===
# Estas chaves devem estar APENAS nas Supabase Edge Functions
# Configure com: supabase secrets set CHAVE=valor
#
# SUPABASE_SERVICE_ROLE_KEY=
# CLAUDE_API_KEY=
# AGRIO_API_KEY=
# GEMINI_API_KEY=
# RESEND_API_KEY=
