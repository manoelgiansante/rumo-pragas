# =============================================
# Rumo Pragas - Variáveis de ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Supabase - Obtenha em https://supabase.com/dashboard/project/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EAS: cadastre ambas como plaintext nos ambientes usados pelo build.

# Google OAuth opcional - Obtenha IDs distintos em
# https://console.cloud.google.com/apis/credentials
# NUNCA reutilize o Web Client ID no iOS/Android. Se o ID específico da
# plataforma estiver ausente ou malformado, o app esconde o botão Google e
# mantém login por email (e Apple no iOS) funcionando.
# Cadastre cada valor público no EAS Environment usado pelo build, por exemplo:
#   eas env:create --environment production --name EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID --value <ios_client_id> --visibility plaintext
# O iOS deve usar bundle com.agrorumo.rumopragas; Android deve usar package
# com.agrorumo.rumopragas + SHA-1 da assinatura correspondente.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Sentry - DSN publico (seguro no client)
# Obtenha em https://sentry.io > Project Settings > Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=
# EAS: cadastre como plaintext nos ambientes usados pelo build.

# Feature flags (default: todas habilitadas)
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# === BUILD-TIME ONLY (EAS secret, NAO expor no client) ===
# Android remote push (FCM v1): cadastre o google-services.json do app
# com.agrorumo.rumopragas como variável do tipo file. O caminho temporário é
# injetado em GOOGLE_SERVICES_JSON e app.config.js o passa ao prebuild:
#   eas env:create --environment production --name GOOGLE_SERVICES_JSON --value ./google-services.json --visibility secret --type file
# Sem este arquivo o build continua apto a alertas locais, mas não registra
# token remoto Android e não é candidato completo para publicação.
#
# Configure como secret no EAS Environment:
#   eas env:create --environment production --name SENTRY_AUTH_TOKEN --value <token> --visibility secret
#
# GOOGLE_SERVICES_JSON=  # file secret; não versionar o JSON
# SENTRY_AUTH_TOKEN=     # upload de source maps do @sentry/react-native

# === CHAVES SERVER-SIDE (NAO colocar no app mobile) ===
# Estas chaves devem estar APENAS nas Supabase Edge Functions
# Configure com: supabase secrets set CHAVE=valor
#
# SUPABASE_SERVICE_ROLE_KEY=
# CLAUDE_API_KEY=
# AGRIO_API_KEY=
# GEMINI_API_KEY=
# RESEND_API_KEY=
