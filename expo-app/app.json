            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePerformanceData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#022822",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.agrorumo.rumopragas",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 5000,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/876377f3-16a0-468a-aba4-97ef96836f1d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "O Rumo Pragas IA usa a câmera para fotografar plantas, folhas, frutos e sintomas visíveis e realizar uma triagem visual educativa e probabilística por IA. O resultado pode estar incorreto e não substitui avaliação profissional."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Rumo Pragas IA usa sua galeria para selecionar uma foto de planta, folha ou fruto e realizar uma triagem visual educativa e probabilística por IA. O resultado pode estar incorreto e não substitui avaliação profissional.",
          "cameraPermission": "O Rumo Pragas IA usa a câmera para fotografar plantas, folhas, frutos e sintomas visíveis e realizar uma triagem visual educativa e probabilística por IA. O resultado pode estar incorreto e não substitui avaliação profissional."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Se você autorizar, o Rumo Pragas IA usa localização aproximada enquanto o app está aberto para consultar temperatura, umidade e precipitação da área e contextualizar o diagnóstico. A permissão é opcional e pode ser revogada nos Ajustes."
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#06281D",
          "defaultChannel": "climate-risk",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "buildReactNativeFromSource": true
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "barStyle": "dark",
          "visibility": "visible"
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      "./plugins/withQuotedSentryXcodeScripts",
      [
        "@sentry/react-native/expo",
        {
          "organization": "rumo-maquinas",
          "project": "rumo-pragas",
          "url": "https://sentry.io/"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "876377f3-16a0-468a-aba4-97ef96836f1d"
      },
      "router": {}
    },
    "owner": "manoelgiansante"
  }
}
