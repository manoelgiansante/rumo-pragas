{
  "expo": {
    "name": "Rumo Pragas IA",
    "slug": "rumo-pragas",
    "version": "1.0.11",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "rumopragas",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#022822"
    },
    "assetBundlePatterns": [
      "assets/icon.png",
      "assets/splash-icon.png",
      "assets/favicon.png",
      "assets/android-icon-monochrome.png"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrorumo.rumopragas",
      "usesAppleSignIn": true,
      "requireFullScreen": true,
      "infoPlist": {
        "RCTNewArchEnabled": true,
        "NSCameraUsageDescription": "O Rumo Pragas IA usa a câmera para fotografar plantas, folhas, frutos e sintomas visíveis e realizar uma triagem visual educativa e probabilística por IA. O resultado pode estar incorreto e não substitui avaliação profissional.",
        "NSPhotoLibraryUsageDescription": "O Rumo Pragas IA usa sua galeria para selecionar uma foto de planta, folha ou fruto e realizar uma triagem visual educativa e probabilística por IA. O resultado pode estar incorreto e não substitui avaliação profissional.",
        "NSLocationWhenInUseUsageDescription": "Se você autorizar, o Rumo Pragas IA usa localização aproximada enquanto o app está aberto para consultar temperatura, umidade e precipitação da área e contextualizar o diagnóstico. A permissão é opcional e pode ser revogada nos Ajustes.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["whatsapp"],
        "UISupportedInterfaceOrientations": ["UIInterfaceOrientationPortrait"],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown"
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyCollectedDataTypes": [
