{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "latest",
        "credentialsSource": "local"
      },
      "android": {
        "image": "latest",
        "buildType": "app-bundle"
      },
      "env": {
        "NODE_ENV": "production",
        "SENTRY_ORG": "rumo-maquinas",
        "SENTRY_PROJECT": "rumo-pragas"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "manoelgiansante@gmail.com",
        "appleTeamId": "5YW9UY5LXP",
        "ascAppId": "6762232682",
        "ascApiKeyId": "C5FD4GNS79",
        "ascApiKeyIssuerId": "315bb9b2-f8be-46c8-b564-1cc997361301",
        "ascApiKeyPath": "/Users/manoelnascimento/.keys/AuthKey_C5FD4GNS79.p8"
      },
      "android": {
        "serviceAccountKeyPath": "./play-store-key.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": true
      }
    }
  }
}
