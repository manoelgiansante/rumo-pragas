{
  "name": "rumo-pragas-app",
  "version": "1.0.11",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "node --stack-size=8000 ./node_modules/typescript/lib/tsc.js --noEmit",
    "validate:diagnosis-contract": "node --experimental-strip-types scripts/validate-diagnose.ts",
    "validate:native-config": "node scripts/validate-native-config.mjs",
    "validate:web-config": "node scripts/validate-web-config.mjs",
    "validate:mcp-sdk": "tsx scripts/test-mcp-sdk.ts",
    "validate:store-assets": "node scripts/validate-store-assets.mjs ios && node scripts/validate-store-assets.mjs android",
    "status:store-submission": "node scripts/store-submission-status.mjs",
    "prepare": "cd .. && husky"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "@tootallnate/once": "^2.0.1",
    "ajv": "^8.17.1",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "brace-expansion": "^5.0.6",
    "esbuild": "^0.28.1",
    "minimatch": "^10.2.3",
    "test-exclude": {
      "minimatch": "^3.0.5"
    },
    "path-to-regexp": "^6.3.0",
    "postcss": "^8.5.10",
    "semver@7": "^7.8.4",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.16",
    "undici": "^6.27.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.1",
    "shell-quote": "^1.8.4",
    "form-data": "^4.0.6",
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^3.14.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@supabase/.*)"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "collectCoverageFrom": [
      "services/**/*.{ts,tsx}",
      "hooks/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "!**/*.d.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/metro-runtime": "~55.0.10",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.99.2",
    "expo": "~55.0.17",
    "expo-apple-authentication": "~55.0.13",
    "expo-application": "~55.0.16",
    "expo-asset": "~55.0.17",
    "expo-auth-session": "~55.0.17",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-navigation-bar": "~55.0.14",
    "expo-notifications": "~55.0.20",
    "expo-print": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.13",
    "expo-system-ui": "~55.0.19",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "i18next": "^25.10.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vercel/node": "^5.7.10",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "private": true,
  "engines": {
    "node": "22.22.3",
    "npm": "10.9.8"
  },
  "packageManager": "npm@10.9.8"
}
